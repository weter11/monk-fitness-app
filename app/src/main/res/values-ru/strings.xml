    <string name="ex_hang_tech">Держите лопатки активными, не просто висите мешком.</string>
    <string name="ex_face_pull">Face Pull (Тяга к лицу)</string>
    <string name="ex_face_pull_desc">Тяните резину к лицу.</string>
    <string name="ex_face_pull_tech">Сосредоточьтесь на задних дельтах и сведении лопаток.</string>
    <string name="ex_superman">Супермен</string>
    <string name="ex_superman_desc">Поднимайте руки и ноги лежа на животе.</string>
    <string name="ex_superman_tech">Задержитесь в верхней точке на 2 секунды.</string>
    <string name="ex_wall_slides">Скольжения у стены</string>
    <string name="ex_wall_slides_desc">Скользите руками вверх и вниз по стене.</string>
    <string name="ex_wall_slides_tech">Прижимайте спину и локти к стене.</string>
    <string name="ex_deep_squat">Глубокий присед</string>
