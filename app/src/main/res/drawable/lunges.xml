<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Head -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M100,40 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />
    <!-- Torso -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M100,50 L100,100" />
    <!-- Front Leg (90 degrees) -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M100,100 L140,100 L140,145" />
    <!-- Back Leg (90 degrees) -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M100,100 L70,110 L70,150" />
    <!-- Floor line -->
    <path
        android:strokeColor="#757575"
        android:strokeWidth="2"
        android:pathData="M40,155 L160,155" />
</vector>
