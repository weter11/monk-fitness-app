<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Head -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M100,50 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />
    <!-- Torso -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:pathData="M100,60 L100,110" />
    <!-- Thighs (deep squat position) -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:pathData="M100,110 L60,110 M100,110 L140,110" />
    <!-- Lower legs -->
    <path
        android:strokeColor="#4CAF50"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:pathData="M60,110 L60,150 M140,110 L140,150" />
    <!-- Floor line -->
    <path
        android:strokeColor="#757575"
        android:strokeWidth="2"
        android:pathData="M40,155 L160,155" />
</vector>
