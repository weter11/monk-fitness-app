# .kilocodeignore — context boundary for the Kilo agent.
# Goal: keep ONLY what we actively work on in context (Kotlin engine/app
# source, build config, and docs). Everything else is excluded to save tokens.
#
# Kept intentionally (NOT ignored):
#   app/src/main/java/**, app/src/test/java/**   -> Kotlin source we edit
#   app/src/main/res/values*/**                  -> string resources
#   *.gradle.kts, gradle.properties, gradle/libs.versions.toml, settings
#   docs/**                                       -> ENGINE/VALIDATION specs we use
#   README.md, kilo.jsonc, .gitignore, .kilocodeignore

# ---------------------------------------------------------------------------
# Build output (generated)
# ---------------------------------------------------------------------------
build/
app/build/
*/build/
bin/
gen/
out/
captures/
.cxx/
.externalNativeBuild/

# ---------------------------------------------------------------------------
# Gradle / in-workspace toolchain & package directories
# ---------------------------------------------------------------------------
.gradle/
.gradle-home/
.gradle-dist/
.kotlin/
android-sdk/
node_modules/
.m2/
**/.cache/

# ---------------------------------------------------------------------------
# Binary / generated / large non-text assets (not useful as text context)
# ---------------------------------------------------------------------------
*.class
*.dex
*.apk
*.aar
*.ap_
*.jar
*.keystore
*.hprof
*.log
*.png
*.jpg
*.jpeg
*.webp
*.tflite
*.so

# Android art assets (vector XML / launcher icons) — not needed for engine work
app/src/main/res/drawable/
app/src/main/res/drawable-*/
app/src/main/res/mipmap/
app/src/main/res/mipmap-*/

